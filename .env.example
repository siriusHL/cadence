# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Get these from your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Test mode keys to start. Create three products in Stripe (Free is implicit / $0).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ELITE=price_...

# --- Market data (server-only) ---
# Twelve Data — quotes + time series. Free tier: 800 calls/day, 8/min.
TWELVE_DATA_KEY=
# Financial Modeling Prep — dividend history + fundamentals. Free: 250 calls/day.
FMP_KEY=

# --- Cron / background jobs ---
# Bearer secret used to authenticate calls to /api/jobs/*. Generate any random
# 32+ char string. Vercel Cron sends this automatically once configured; for
# external schedulers, send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
