# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Get these from your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Test mode keys to start. Create three products in Stripe (Free is implicit / $0).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ELITE=price_...

# --- Market data (server-only) ---
# Twelve Data — quotes + time series. Free tier: 800 calls/day, 8/min.
TWELVE_DATA_KEY=
# Financial Modeling Prep — dividend history + fundamentals. Free: 250 calls/day.
FMP_KEY=

# --- Email (support messaging, server-only) ---
# Resend API key — https://resend.com. Optional: if unset, in-app messaging
# still works, only the email notifications are skipped.
RESEND_API_KEY=
# Verified "from" address for outbound mail, e.g. "Cadence <support@cadence.app>".
EMAIL_FROM=
# Inbox that receives user support messages.
SUPPORT_EMAIL=

# --- Support admin (server-only) ---
# Bearer secret for the support-reply endpoint (POST /api/messages/:id/reply).
SUPPORT_ADMIN_SECRET=


