# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Get these from your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Test mode keys to start. Create three products in Stripe (Free is implicit / $0).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ELITE=price_...

# --- Market data (server-only) ---
# Twelve Data — quotes + time series. Free tier: 800 calls/day, 8/min.
TWELVE_DATA_KEY=
# Financial Modeling Prep — dividend history + fundamentals. Free: 250 calls/day.
FMP_KEY=

# --- Google Calendar sync (Premium / Elite) ---
# OAuth client from Google Cloud Console → APIs & Services → Credentials.
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback
# 32 random bytes, base64-encoded. Used to encrypt refresh tokens at rest.
# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_ENC_KEY=
# Random string used to sign OAuth state (CSRF). 32+ chars.
GOOGLE_OAUTH_STATE_SECRET=


