# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# e2e (Selenium + pytest + Allure) — generated artifacts only
tests/e2e/.allure-results/
tests/e2e/allure-report/
tests/e2e/.pytest_cache/
tests/e2e/report.html
__pycache__/
*.pyc

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
env.txt

# claude code — per-developer tooling (launch configs, local settings)
.claude/

# supabase
supabase/.temp
supabase/.branches

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# daily digest — generated email artifacts (built in CI, never committed)
/digest.html
/digest.txt
/digest-subject.txt
